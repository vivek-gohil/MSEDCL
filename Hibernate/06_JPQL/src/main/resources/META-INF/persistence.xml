<?xml version="1.0" encoding="UTF-8"?>
<!-- Root element of JPA configuration. Defines persistence units and database 
	configuration. -->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
	version="3.0">
	<persistence-unit name="employee-unit">
		<class>com.msedcl.main.entity.EmployeeDetails</class>
		<properties>
			<!--MYSQL Properties-->
			<property name="jakarta.persistence.jdbc.driver"
				value="com.mysql.cj.jdbc.Driver" />
			<property name="jakarta.persistence.jdbc.url"
				value="jdbc:mysql://localhost:3306/msedcldb" />
			<property name="jakarta.persistence.jdbc.user" value="root" />
			<property name="jakarta.persistence.jdbc.password" value="root123" />

			<!--Hibernate Properties-->
			<property name="hibernate.show_sql" value="true" />
			<property name="hibernate.format_sql" value="true" />
			<property name="hibernate.hbm2ddl.auto" value="none" />
		</properties>
	</persistence-unit>
</persistence>